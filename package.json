{
  "name": "metal-squad",
  "version": "0.0.1",
  "description": "Orquestrador de pipelines de desenvolvimento assistido por IA sobre spec-kit",
  "type": "module",
  "bin": {
    "metal-squad": "./dist/index.js",
    "msq": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && rm -rf dist/web/static dist/web/client && cp -r src/web/static dist/web/static && node esbuild.web.mjs && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run",
    "prepare": "husky",
    "clean:db": "rm -f ~/.local/share/metal-squad/app.db && rm -rf .metal-squad",
    "web": "npm run build && msq web --host 0.0.0.0"
  },
  "engines": {
    "node": ">=20.17.0"
  },
  "dependencies": {
    "@napi-rs/keyring": "^1.1.6",
    "@types/ws": "^8.18.1",
    "better-sqlite3": "^11.8.1",
    "commander": "^13.1.0",
    "ink": "^5.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.21.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitest/coverage-v8": "^3.2.7",
    "esbuild": "^0.28.1",
    "eslint": "^9.18.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^3.0.2"
  }
}
