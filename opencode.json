{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/claude-opus-4-6",
  "small_model": "opencode/claude-sonnet-4-6",
  "shell": "zsh",
  "instructions": ["AGENTS.md"],
  "mcp": {
    "dora": {
      "type": "stdio",
      "command": ["dora", "mcp"],
      "enabled": true
    }
  },
  "permission": {
    "bash": "allow",
    "write": "allow",
    "edit": "allow",
    "skill": { "*": "allow" }
  },
  "lsp": true,
  "compaction": { "auto": true, "tail_turns": 15 }
}
